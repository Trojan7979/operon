# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash-preview-04-17
ENABLE_VERTEX_AI=false
ENABLE_DEV_LLM_ENDPOINT=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./operon.db
# For Cloud SQL (Postgres):
# DATABASE_URL=postgresql+asyncpg://user:password@/dbname?host=/cloudsql/project:region:instance

# Auth
SECRET_KEY=your-super-secret-key-change-this-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=true

# MCP server identifiers or endpoints
MCP_CALENDAR_SERVER=calendar-mcp
MCP_TASK_SERVER=task-manager-mcp
MCP_NOTES_SERVER=notes-mcp
MCP_HR_SERVER=hris-mcp
MCP_PROCUREMENT_SERVER=procurement-mcp
